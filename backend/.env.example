# ============================================================
#  Android Map Directory - Backend (Next.js) environment vars
#
#  LOCAL:  copy this file to ".env.local" and fill in values.
#  VERCEL: set the same keys in Project Settings -> Environment Variables.
#  NEVER commit the real values (.env*.local is gitignored).
# ============================================================

# --- Supabase (data API / PostgREST) ---
# Supabase Dashboard -> Project Settings -> API.
#   SUPABASE_URL                = "Project URL"
#   SUPABASE_SERVICE_ROLE_KEY   = "service_role" secret key (NOT the anon key)
# The service_role key bypasses Row Level Security, so it is SERVER-ONLY:
# never expose it to the Android app or use a NEXT_PUBLIC_ prefix for it.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# --- API security ---
# Secret required in the "X-API-Key" header for write endpoints (POST/PUT).
# The Android app never gets this key; only the server + admin panel know it.
# Generate one:  node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
API_KEY=change-me-to-a-long-random-secret

# --- CORS ---
# Comma-separated allowed origins, or "*" to allow all (fine for a public read API).
CORS_ORIGIN=*

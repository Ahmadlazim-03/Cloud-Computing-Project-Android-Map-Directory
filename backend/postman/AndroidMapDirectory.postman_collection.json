{
  "info": {
    "name": "Android Map Directory API",
    "description": "REST API contract for the Android Map Directory campus app. Set the collection variables `baseUrl` and `apiKey`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000", "type": "string" },
    { "key": "apiKey", "value": "change-me-to-a-long-random-secret", "type": "string" }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{baseUrl}}/api/health", "host": ["{{baseUrl}}"], "path": ["api", "health"] }
      }
    },
    {
      "name": "List Categories",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{baseUrl}}/api/categories", "host": ["{{baseUrl}}"], "path": ["api", "categories"] }
      }
    },
    {
      "name": "List Places",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{baseUrl}}/api/places", "host": ["{{baseUrl}}"], "path": ["api", "places"] }
      }
    },
    {
      "name": "List Places - filter by category",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/places?category=cafe",
          "host": ["{{baseUrl}}"],
          "path": ["api", "places"],
          "query": [{ "key": "category", "value": "cafe" }]
        }
      }
    },
    {
      "name": "List Places - search q",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/places?q=kopi",
          "host": ["{{baseUrl}}"],
          "path": ["api", "places"],
          "query": [{ "key": "q", "value": "kopi" }]
        }
      }
    },
    {
      "name": "List Places - sort by distance",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/places?lat=-7.2756&lng=112.7946&sort=distance&limit=10",
          "host": ["{{baseUrl}}"],
          "path": ["api", "places"],
          "query": [
            { "key": "lat", "value": "-7.2756" },
            { "key": "lng", "value": "112.7946" },
            { "key": "sort", "value": "distance" },
            { "key": "limit", "value": "10" }
          ]
        }
      }
    },
    {
      "name": "Place Detail",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/places/1?lat=-7.2756&lng=112.7946",
          "host": ["{{baseUrl}}"],
          "path": ["api", "places", "1"],
          "query": [
            { "key": "lat", "value": "-7.2756" },
            { "key": "lng", "value": "112.7946" }
          ]
        }
      }
    },
    {
      "name": "Create Place (admin)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-API-Key", "value": "{{apiKey}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"category_id\": 1,\n  \"name\": \"Kafe Baru\",\n  \"latitude\": -7.2760,\n  \"longitude\": 112.7950,\n  \"address\": \"Jl. Kampus No. 99\",\n  \"opening_hours\": \"08:00-22:00\",\n  \"description\": \"Kafe baru dekat gerbang.\",\n  \"rating\": 4.3,\n  \"photo_url\": \"https://picsum.photos/seed/new/400/300\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/places", "host": ["{{baseUrl}}"], "path": ["api", "places"] }
      }
    },
    {
      "name": "Update Place (admin)",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-API-Key", "value": "{{apiKey}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"rating\": 4.9,\n  \"description\": \"Deskripsi diperbarui.\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/places/1", "host": ["{{baseUrl}}"], "path": ["api", "places", "1"] }
      }
    },
    {
      "name": "Add Review",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"rating\": 5,\n  \"comment\": \"Tempatnya nyaman!\",\n  \"user_id\": \"device-123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/places/1/reviews",
          "host": ["{{baseUrl}}"],
          "path": ["api", "places", "1", "reviews"]
        }
      }
    }
  ]
}
